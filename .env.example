# Copy to .env and fill in from your Google Cloud OAuth "Desktop app" client.
# (APIs & Services -> Credentials -> Create credentials -> OAuth client ID -> Desktop app)
# .env is gitignored. PKCE is used; the secret is non-confidential for desktop clients
# but Google's token endpoint still expects it, so include it.

GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
