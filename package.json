{
  "name": "fitbit_macos_extension",
  "version": "0.1.0",
  "description": "macOS widget showing Fitbit Air health stats via the Google Health API",
  "main": "./out/main/index.js",
  "author": "torokdavid98@gmail.com",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  },
  "build": {
    "appId": "com.fitbit.macos.extension",
    "productName": "Fitbit macOS Extension",
    "mac": {
      "category": "public.app-category.healthcare-fitness",
      "target": "dmg"
    },
    "files": [
      "out/**/*"
    ]
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
